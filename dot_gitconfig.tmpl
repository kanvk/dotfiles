[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
# Includes go first so the static template wins on conflict (later wins in git).
[include]
	path = ~/.gitconfig.local
[include]
	path = ~/.gitconfig.machine
[user]
	email = {{ .email }}
	name = {{ .name }}
{{- if and (hasKey . "use_gpg_signing") .use_gpg_signing }}
	signingKey = {{ .gpg_signing_key }}
{{- end }}
[core]
	editor = nvim
	pager = delta
{{- if and (hasKey . "use_gpg_signing") .use_gpg_signing }}
[commit]
	gpgsign = true
[gpg]
	format = openpgp
[tag]
	forceSignAnnotated = true
	gpgsign = true
{{- else }}
[commit]
	gpgsign = false
{{- end }}
[credential "https://huggingface.co"]
	provider = generic
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential "https://git.overleaf.com"]
	provider = generic
[alias]
	ignore   = update-index --skip-worktree
	unignore = update-index --no-skip-worktree
	ignored = !git ls-files -v | grep '^S'
[diff "jupyternotebook"]
	command = git-nbdiffdriver diff
[merge "jupyternotebook"]
	driver = git-nbmergedriver merge %O %A %B %L %P
	name = jupyter notebook merge driver
[interactive]
	difffilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	# Match bat's BAT_THEME in dot_config/zsh/omz-custom/export.zsh — delta links
	# bat as a library, so the theme name string is identical between the two.
	syntax-theme = Catppuccin Macchiato
[diff]
	tool = nvimdiff
[merge]
	tool = nvimdiff
	conflictStyle = zdiff3
[pull]
	rebase = false
	ff = only
[push]
	followTags = true
	autoSetupRemote = true
[difftool]
	prompt = false
[mergetool]
	prompt = false
[difftool "nbdime"]
	cmd = git-nbdifftool diff \"$LOCAL\" \"$REMOTE\" \"$BASE\"
[mergetool "nbdime"]
	cmd = git-nbmergetool merge \"$BASE\" \"$LOCAL\" \"$REMOTE\" \"$MERGED\"
