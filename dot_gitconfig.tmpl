[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[user]
	email = {{ .email }}
	name = {{ .name }}
{{- if .gpg_signing_key }}
	signingKey = {{ .gpg_signing_key }}
{{- end }}
[core]
	editor = nvim
	pager = delta
{{- if .gpg_signing_key }}
[commit]
	gpgsign = true
[gpg]
	format = openpgp
[tag]
	forceSignAnnotated = true
	gpgsign = true
{{- else }}
[commit]
	gpgsign = false
{{- end }}
[credential "https://huggingface.co"]
	provider = generic
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential "https://git.overleaf.com"]
	provider = generic
[alias]
	ignore   = update-index --skip-worktree
	unignore = update-index --no-skip-worktree
	ignored = !git ls-files -v | grep '^S'
[diff "jupyternotebook"]
	command = git-nbdiffdriver diff
[merge "jupyternotebook"]
	driver = git-nbmergedriver merge %O %A %B %L %P
	name = jupyter notebook merge driver
[interactive]
	difffilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
[merge]
	conflictStyle = zdiff3
[pull]
	rebase = false
	ff = only
[push]
	followTags = true
	autoSetupRemote = true
[difftool]
	prompt = false
[mergetool]
	prompt = false
[difftool "nbdime"]
	cmd = git-nbdifftool diff \"$LOCAL\" \"$REMOTE\" \"$BASE\"
[mergetool "nbdime"]
	cmd = git-nbmergetool merge \"$BASE\" \"$LOCAL\" \"$REMOTE\" \"$MERGED\"
# Personal-but-not-secret overrides (insteadOf rules etc.) — encrypted-tracked
# under chezmoi as encrypted_private_dot_gitconfig.local.age, gated on
# encrypt_locals=true. Per-machine non-portable overrides go in
# ~/.gitconfig.machine, which is intentionally outside the chezmoi source.
# Both includes silently no-op when the target file is missing; later wins.
[include]
	path = ~/.gitconfig.local
[include]
	path = ~/.gitconfig.machine
