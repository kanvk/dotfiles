#compdef ts
# Hand-written completion for the `ts` function in alias.zsh.
# `sesh list` already merges live tmux sessions, sesh config entries, and
# zoxide directories into one newline-separated list — exactly the candidate
# set `ts` accepts. fzf-tab (configured in dot_zshrc) renders the picker.
# Frecency order is preserved by the `sort false` zstyle on `:ts:*` in
# dot_zshrc — fzf-tab re-sorts on its own and ignores compadd's `-V` group
# flag, so the zstyle is the only knob that actually works here.

local -a targets
targets=(${(f)"$(sesh list 2>/dev/null)"})
_describe 'session/dir' targets
