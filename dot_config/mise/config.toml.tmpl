# Managed by chezmoi (source: dot_config/mise/config.toml.tmpl).
# Tools come from the resolved tier's `mise` list in .chezmoidata.yaml;
# run_onchange_after_15-mise-tools.sh.tmpl provisions them on apply.
{{- $resolved := includeTemplate "resolve-tier" (dict "tier" .tier "tiers" .tiers "acc" dict) | fromJson }}
{{- $tools := index $resolved "mise" | default list }}
{{- if $tools }}
[tools]
{{- range $tools }}
{{- if not (contains "@" .) }}{{ fail (printf "mise entry %q must be tool@version" .) }}{{ end }}
{{- $parts := splitList "@" . }}
"{{ $parts | initial | join "@" }}" = "{{ $parts | last }}"
{{- end }}
{{- end }}
