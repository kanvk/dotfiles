" Basic .vimrc for vim emulators (VSCode-Vim, IdeaVim, etc.).
" Editor-agnostic options only.

let mapleader = " "
let maplocalleader = ","

set number
set relativenumber

set expandtab
set tabstop=4
set softtabstop=4
set shiftwidth=4
set smartindent

set hidden
set nospell
set nowrap
set clipboard=unnamedplus

set signcolumn=yes
set colorcolumn=120

set listchars=tab:→\ ,eol:¶,space:·,trail:▒,nbsp:␣,extends:»,precedes:«
set nolist
