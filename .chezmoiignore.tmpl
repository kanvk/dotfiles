{{/*
   Files and patterns excluded from `chezmoi apply`.
   IMPORTANT: chezmoi matches these against DESTINATION paths (i.e. how the
   file appears under $HOME), not source paths. So write `.config/foo` and
   `.ssh/bar`, NOT `dot_config/foo` or `private_dot_ssh/bar`.

   This file is itself a template — use {{ if ... }} for OS/host-conditional ignores.
*/}}

# Source-tree docs + dev tooling: never apply to $HOME
README.md
CLAUDE.md
tests/**
justfile
docs/**
.pre-commit-config.yaml

# Example file shown in docs as a starter for the user-created config.machine;
# we don't want it landing as the actual ~/.ssh/config.machine.example file.
.ssh/config.machine.example

{{- if not (and (hasKey . "encrypt_locals") .encrypt_locals) }}
# Encrypted personal-but-not-secret locals (insteadOf rules, GHE SSH alias,
# Claude Code config, Codex CLI config + context7 API key).
# Excluded unless the user opted in at init time AND has the age identity in
# place. Without the identity, decryption would fail and apply would error.
# The `hasKey` guard makes a chezmoi.toml without `encrypt_locals` set
# default to "ignore" rather than erroring on a missing-key template lookup.
.gitconfig.local
.ssh/config.local
.config/sesh/sesh.local.toml
.claude/settings.json
.codex/config.toml
.codex/AGENTS.md
{{- end }}

# Defensive: never vendor sheldon's plugin cache, even if accidentally re-added.
.local/share/sheldon/repos/**

# Runtime/ephemeral Claude Code state — managed at runtime, not tracked.
.claude/.credentials.json
.claude/history.jsonl
.claude/projects/**
.claude/shell-snapshots/**
.claude/todos/**
.claude/ide/**
.claude/statsig/**
.claude/backups/**
.claude/logs/**
.claude/settings.local.json

# Runtime/ephemeral Codex CLI state — auth, sessions, caches, logs.
.codex/auth.json
.codex/history.jsonl
.codex/installation_id
.codex/version.json
.codex/.personality_migration
.codex/cache/**
.codex/log/**
.codex/logs_*.sqlite*
.codex/state_*.sqlite*
.codex/memories/**
.codex/sessions/**
.codex/shell_snapshots/**
.codex/skills/**
.codex/tmp/**
.codex/.tmp/**
.codex/models_cache.json
