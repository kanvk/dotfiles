# Starter for ~/.ssh/config.machine — copy this to ~/.ssh/config.machine and
# fill in entries for THIS machine's network. Intentionally outside the chezmoi
# source so machine-specific IPs / hostnames never land in the public repo.
#
# Personal-but-portable hosts that you want synced across all your machines
# go in ~/.ssh/config.local instead — that path is encrypted-tracked under
# chezmoi when encrypt_locals=true at init time.
#
# Do NOT commit this file or its eventual ~/.ssh/config.machine to a public repo.

# Example: home box on the LAN
# Host rpi
#     HostName <ip-or-hostname>
#     User <user>
#     Port 22
#     IdentityFile ~/.ssh/<key>
#     IdentitiesOnly yes
#     AddKeysToAgent yes

# Example: university / institution login server
# Host arc
#     HostName <host.example.edu>
#     User <user>
#     IdentityFile ~/.ssh/<key>
#     IdentitiesOnly yes
#     AddKeysToAgent yes

# Example: lab proxy + internal hosts via ProxyJump
# Host lab-proxy
#     HostName <proxy-ip>
#     Port <port>
#     ForwardAgent yes
#     User <user>
#     IdentityFile ~/.ssh/<key>
#     IdentitiesOnly yes
#     AddKeysToAgent yes
#
# Host *.internal.example
#     ProxyJump lab-proxy
#     User <user>
#     IdentityFile ~/.ssh/<key>
#     IdentitiesOnly yes
#     AddKeysToAgent yes
