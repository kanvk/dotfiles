# SSH config — universal entries.
# Per-machine non-portable hosts (lab IPs, LAN boxes) live in
# ~/.ssh/config.machine, which is intentionally outside the chezmoi source.
# Personal-but-portable hosts and aliases (e.g. the github.com-ghe routing
# alias) live in ~/.ssh/config.local — encrypted-tracked under chezmoi when
# encrypt_locals=true; otherwise absent and the include silently no-ops.

Host *
  ServerAliveInterval 30
  ServerAliveCountMax 3

Include ~/.ssh/config.local
Include ~/.ssh/config.machine

# GitHub default — used by `git@github.com:…` URLs.
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/las
    IdentitiesOnly yes
    AddKeysToAgent yes
