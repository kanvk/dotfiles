# Starter for ~/.ssh/config.local — copy this to ~/.ssh/config.local and fill in
# host entries for your network/lab/home boxes. Not tracked by chezmoi.
#
# Do NOT commit this file to a public repo.

# Example: home box on the LAN
# Host rpi
#     HostName <ip-or-hostname>
#     User <user>
#     Port 22
#     IdentityFile ~/.ssh/<key>
#     IdentitiesOnly yes
#     AddKeysToAgent yes

# Example: university / institution login server
# Host arc
#     HostName <host.example.edu>
#     User <user>
#     IdentityFile ~/.ssh/<key>
#     IdentitiesOnly yes
#     AddKeysToAgent yes

# Example: lab proxy + internal hosts via ProxyJump
# Host las-proxy
#     HostName <proxy-ip>
#     Port <port>
#     ForwardAgent yes
#     User <user>
#     IdentityFile ~/.ssh/<key>
#     IdentitiesOnly yes
#     AddKeysToAgent yes
#
# Host *.internal.example
#     ProxyJump las-proxy
#     User <user>
#     IdentityFile ~/.ssh/<key>
#     IdentitiesOnly yes
#     AddKeysToAgent yes
