#!/usr/bin/env bash
#
# Syncs Neovim plugins to the versions pinned in lazy-lock.json.
#
# lock-hash: {{ include "dot_config/nvim/lazy-lock.json" | sha256sum }}

set -euo pipefail
{{ template "brew-path-bootstrap" . }}
# Brew's nvim is preferred over the apt `neovim` system package (a dep of
# `python3-pynvim`, version-locked to whatever the distro ships) — the
# bootstrap above puts brew first on PATH so `command -v nvim` resolves there.
if ! command -v nvim >/dev/null 2>&1; then
  echo "nvim not installed yet — skipping Lazy sync"
  exit 0
fi

echo "==> nvim +Lazy! restore +qa"
# Lazy.nvim bootstraps itself on first nvim launch from init.lua, so this call
# both installs and restores to the locked versions. Errors ignored to keep
# apply flowing even if a single plugin temporarily fails to fetch.
#
# `timeout` guards against a known lazy.nvim race where `+qa` deadlocks with an
# in-flight async restore task and nvim hangs indefinitely. A real first-time
# restore lands around 1–2 min — 3 min leaves headroom but bails fast if a
# deadlock actually hits. Errors are tolerated so apply keeps flowing.
timeout --kill-after=30s 3m \
  nvim --headless "+Lazy! restore" +qa 2>/dev/null || true
