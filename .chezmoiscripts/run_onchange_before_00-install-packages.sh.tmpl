{{- /*
  Resolve the chosen tier (default "base" if the cached chezmoi.toml predates
  the tier prompt) into a flat per-manager package set. After this block,
  $resolved is a dict like {apt: [...], brew: [...], uvx: [...], ...} that
  the rest of the script consumes via $resolved.<manager>. The `uvx` list
  is installed via `uv tool` (see the python-tools block below).
*/ -}}
{{- $tierName := "base" -}}
{{- if hasKey . "tier" -}}{{- $tierName = .tier -}}{{- end -}}
{{- $resolved := includeTemplate "resolve-tier" (dict "tier" $tierName "tiers" .tiers "acc" dict) | fromJson -}}
#!/usr/bin/env bash
#
# Installs packages declared in .chezmoidata.yaml for the chosen tier.
# chezmoi re-runs this script whenever its rendered content changes — which
# happens automatically when any package list is edited or when the user's
# selected tier changes (the hash below captures both).
#
# Additivity contract: every step here is install-or-upgrade only — never
# uninstall, prune, or autoremove. Anything the user installs ad-hoc on a
# machine survives a later `chezmoi apply`. Cleanup is opt-in and manual
# (`brew bundle cleanup --file=<bundle>`, `nala autoremove`, etc.). See the
# CLAUDE.md "user intent, not exclusivity" bullet for the rationale.
#
# tier: {{ $tierName }}
# packages-hash: {{ $resolved | toYaml | sha256sum }}

set -euo pipefail

# --- disable analytics / telemetry for the install run ---
# These env vars are also set by dot_config/zsh/omz-custom/export.zsh, but that
# only takes effect inside an interactive zsh — `chezmoi apply` runs this
# script under bash before the user's shell ever loads. Set them here so the
# very first install (and every subsequent re-run) is opted out by default.
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_ENV_HINTS=1
export DO_NOT_TRACK=1   # community-standard env honored by gh, glab, others

# --- sudo keepalive ---
# One up-front sudo prompt instead of two-or-three: apt at the start, brew's
# installer mid-pipeline, and the post-install `usermod` in
# run_once_after_70-default-shell each consume their own creds and the
# default 5-minute sudo cache typically expires across the brew install.
# Validate creds once, then refresh in the background every minute. The loop
# self-terminates when this script's PID is gone (kill -0 $$ guard inside the
# subshell — $$ stays the parent PID across `( )`), so an orphaned keepalive
# can't survive a hard chezmoi crash. The trap covers normal exits.
#
# Skipped silently if sudo is unavailable or the user has no sudo (the rest
# of the pipeline already gates each `sudo` invocation on `command -v sudo`).
if command -v sudo >/dev/null 2>&1 && sudo -v 2>/dev/null; then
  ( while kill -0 $$ 2>/dev/null; do sudo -n true 2>/dev/null; sleep 60; done ) &
  _sudo_keepalive_pid=$!
  trap 'kill "$_sudo_keepalive_pid" 2>/dev/null || true' EXIT
fi

# --- install-error capture ---
# Each install step appends to _install_errors on failure instead of aborting
# the pipeline. The "==> Install summary" block at the end of this script
# surfaces every recorded failure in one place — a single visual target instead
# of having to scroll the install log. Per-item loops (uv tool, cargo, npm, go,
# bun, gh-extensions) record one entry per failed item; the apt batch and
# brew-bundle batch record one entry per failed batch (scroll up for the
# specific formula). The script always exits 0 so chezmoi proceeds to
# run_onchange_after scripts even when individual packages didn't install.
#
# Errors are also persisted to ERR_LOG so run_after_99-final-summary can
# re-display them at the very end of the apply (where they won't be buried
# under the after-* scripts' output). Truncate the log here at the start of
# every install run so stale entries from a previous apply don't carry over.
ERR_LOG="${TMPDIR:-/tmp}/chezmoi-apply-errors-${USER:-$(id -un)}.log"
: > "$ERR_LOG"
_install_errors=()
_record_install_failure() { _install_errors+=("$1"); printf '%s\n' "$1" >> "$ERR_LOG"; }

echo "==> Installing tier: {{ $tierName }}"

# --- chezmoi version check (advisory) ---
# Features used: .chezmoiexternal, lookPath, promptStringOnce, age+SSH identity.
# All present in 2.50+; warn (don't fail) if older.
if command -v chezmoi >/dev/null 2>&1; then
  _czm_ver="$(chezmoi --version 2>/dev/null | head -1 | grep -oE 'v[0-9]+\.[0-9]+' | head -1 | tr -d v)"
  _czm_major="${_czm_ver%%.*}"; _czm_minor="${_czm_ver##*.}"
  if [ "${_czm_major:-0}" -lt 2 ] || { [ "$_czm_major" -eq 2 ] && [ "${_czm_minor:-0}" -lt 50 ]; }; then
    echo "warning: chezmoi $_czm_ver is older than the recommended >= 2.50; some templates may misbehave" >&2
  fi
  unset _czm_ver _czm_major _czm_minor
fi

{{ if and .is_debian_like (index $resolved "apt") -}}
# --- apt / nala (Debian-based Linux) ---
if command -v sudo >/dev/null 2>&1 && command -v apt-get >/dev/null 2>&1; then
  # Bootstrap nala first so the rest of this run benefits from its parallel
  # downloads + nicer progress UI. nala is itself in the apt list, so this is a
  # one-time bootstrap on a brand-new machine.
  if ! command -v nala >/dev/null 2>&1; then
    echo "==> Bootstrapping nala via apt-get"
    sudo apt-get update -y
    sudo apt-get install -y --no-install-recommends nala || true
  fi

  if command -v nala >/dev/null 2>&1; then
    echo "==> Installing apt packages via nala"
    sudo nala update
    # Upgrade already-installed packages before adding new ones, so the system
    # is current on every apply (incl. the very first). Non-fatal: a held-back
    # package shouldn't abort the install pipeline.
    sudo nala upgrade -y \
      || _record_install_failure "apt: nala upgrade reported errors (see log above)"
    sudo nala install -y{{ range (index $resolved "apt") }} {{ . | quote }}{{ end }} \
      || _record_install_failure "apt: nala batch reported errors (see log above)"
  else
    echo "==> Installing apt packages via apt-get (nala unavailable)"
    sudo apt-get update -y
    sudo apt-get upgrade -y \
      || _record_install_failure "apt: apt-get upgrade reported errors (see log above)"
    sudo apt-get install -y --no-install-recommends{{ range (index $resolved "apt") }} {{ . | quote }}{{ end }} \
      || _record_install_failure "apt: apt-get batch reported errors (see log above)"
  fi
fi
{{- end }}

{{ if index $resolved "brew" -}}
# --- Homebrew ---
if ! command -v brew >/dev/null 2>&1; then
  echo "==> Installing Homebrew (NONINTERACTIVE)"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Ensure brew is on PATH for the rest of this script.
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

echo "==> Installing brew packages via brew bundle"
# Generate Brewfile from the resolved tier set at apply time. Tap-prefixed
# entries (foo/tap/bar) auto-tap. We deliberately don't pass `--cleanup` — it
# removes anything not in the Brewfile, which is too aggressive for a dotfiles
# repo; the user can run `brew bundle cleanup --file=...` manually if they want it.
_brewfile="$(mktemp)"
cat > "$_brewfile" <<'BREWFILE'
{{- range (index $resolved "brew") }}
{{- if hasPrefix "cask:" . }}
cask "{{ trimPrefix "cask:" . }}"
{{- else }}
brew "{{ . }}"
{{- end }}
{{- end }}
BREWFILE

# Run brew bundle WITHOUT --quiet so progress + per-formula failures are
# visible. `brew bundle install` already continues past per-formula failures
# and reports a summary. Don't use `|| true` — let pipefail surface errors,
# but ALSO follow up with `brew bundle check` to make missing formulas obvious.
# (No --no-lock: the flag was removed when bundle stopped emitting Brewfile.lock.json.)
brew bundle install --file="$_brewfile" || _bundle_rc=$?
if [ "${_bundle_rc:-0}" -ne 0 ]; then
  echo "==> brew bundle reported errors — checking what's still missing:"
  brew bundle check --file="$_brewfile" --verbose || true
  _record_install_failure "brew: bundle reported errors (scroll up for which formulas)"
fi
unset _bundle_rc
rm -f "$_brewfile"
unset _brewfile
{{- end }}

{{ if index $resolved "uvx" -}}
# --- python tools (YAML key `uvx:`, installer is `uv tool`) ---
# uv autoselects (or auto-downloads) a managed Python the first time a tool
# is installed — no UV_PYTHON pin and no pyenv coupling.
if command -v uv >/dev/null 2>&1; then
  echo "==> Installing python tools via uv tool"
  # Entries can carry extra `uv tool install` args after the package name, e.g.
  # `mdformat --with mdformat-frontmatter mdformat-gfm` — plugin libraries with
  # no executables that need to live inside the tool's own venv. `uv tool install`
  # only accepts one package per `--with` flag, so the loop expands a single
  # `--with X Y Z` group into `--with X --with Y --with Z` (each non-flag arg
  # following `--with` gets its own `--with`). Other flags (e.g. `--python 3.11`)
  # pass through verbatim. Input comes from .chezmoidata.yaml (trusted), so the
  # unquoted word-split is intentional.
  for _pkg in{{ range (index $resolved "uvx") }} {{ . | quote }}{{ end }}; do
    # shellcheck disable=SC2086
    set -- $_pkg
    _name="$1"
    _args=()
    _need_with=0
    for _arg in "$@"; do
      case "$_arg" in
        --with) _need_with=1 ;;
        --*)    _args+=("$_arg"); _need_with=0 ;;
        *)
          if [ "$_need_with" = "1" ]; then _args+=(--with "$_arg")
          else                              _args+=("$_arg")
          fi
          ;;
      esac
    done
    uv tool install "${_args[@]}" 2>/dev/null \
      || uv tool upgrade "$_name" \
      || _record_install_failure "uv tool: $_name"
  done
  unset _pkg _name _args _arg _need_with
fi
{{- end }}

{{ if index $resolved "npm" -}}
# --- npm (global) ---
if command -v npm >/dev/null 2>&1; then
  echo "==> Installing npm global packages"
  for _pkg in{{ range (index $resolved "npm") }} {{ . | quote }}{{ end }}; do
    npm install -g "$_pkg" || _record_install_failure "npm: $_pkg"
  done
  unset _pkg
fi
{{- end }}

{{ if index $resolved "cargo" -}}
# --- rustup bootstrap (so `cargo install` below has a toolchain) ---
# Brew installs rustup-init only; we still have to run it to pull a stable
# toolchain. Skip if cargo is already on PATH (existing rustup install,
# brew `rust` formula, or system rustc). --no-modify-path keeps PATH clean
# (cargo bin dir is already in dot_config/zsh/omz-custom/export.zsh).
if ! command -v cargo >/dev/null 2>&1; then
  if command -v rustup-init >/dev/null 2>&1; then
    echo "==> Bootstrapping rustup default toolchain"
    rustup-init -y --default-toolchain stable --no-modify-path --quiet
  fi
  # rustup-init places cargo at $HOME/.cargo/bin — make it visible to this script.
  [ -d "$HOME/.cargo/bin" ] && export PATH="$HOME/.cargo/bin:$PATH"
fi

# --- cargo ---
if command -v cargo >/dev/null 2>&1; then
  echo "==> Installing cargo packages"
  # `cargo install` is idempotent (no-ops if already at requested version;
  # feature/source changes do trigger a reinstall). Install one-at-a-time +
  # `|| true` so a single bad crate (e.g. missing system lib at build time)
  # doesn't abort the whole apply pipeline. Use `cargo install-update -a`
  # (from cargo-update) afterward to refresh.
  #
  # Each entry can carry extra `cargo install` args after the crate name, e.g.
  # `coreutils --features unix`. We word-split the entry into positional params
  # so those args reach cargo intact. shellcheck-disable on the unquoted
  # expansion is intentional: input comes from .chezmoidata.yaml (trusted).
  #
  # Skip if the crate is already installed. cargo install's built-in idempotency
  # is unreliable when --features is passed: it rebuilds even when name+version+
  # features+rustc all match (most visibly for uutils coreutils, whose `unix`
  # feature resolves through ~100 sub-features). Refresh is a separate, manual
  # step via `cargo install-update -a`.
  for _crate in{{ range (index $resolved "cargo") }} {{ . | quote }}{{ end }}; do
    # shellcheck disable=SC2086
    set -- $_crate
    if cargo install --list 2>/dev/null | grep -q "^$1 v"; then
      continue
    fi
    cargo install "$@" || {
      echo "warning: cargo install $_crate failed (missing system dep? check apt list)" >&2
      _record_install_failure "cargo: $1"
    }
  done
  unset _crate
fi
{{- end }}

{{ if index $resolved "go" -}}
# --- go install <module>@latest ---
if command -v go >/dev/null 2>&1; then
  echo "==> Installing go packages"
  for _mod in{{ range (index $resolved "go") }} {{ . | quote }}{{ end }}; do
    go install "${_mod}@latest" || _record_install_failure "go: $_mod"
  done
  unset _mod
fi
{{- end }}

{{ if index $resolved "bun" -}}
# --- bun (global) ---
if command -v bun >/dev/null 2>&1; then
  echo "==> Installing bun global packages"
  for _pkg in{{ range (index $resolved "bun") }} {{ . | quote }}{{ end }}; do
    bun add -g "$_pkg" || _record_install_failure "bun: $_pkg"
  done
  unset _pkg
fi
{{- end }}

{{ if index $resolved "gh_extensions" -}}
# --- gh CLI extensions ---
# `gh extension install OWNER/REPO` works without `gh auth login` for public
# extensions (uses the unauth GitHub API), but rate-limit failures or sandbox
# quirks shouldn't break the rest of the install pipeline — fall through to a
# warning. Re-runs are handled by `gh extension upgrade` (install fails with
# "already installed" otherwise).
if command -v gh >/dev/null 2>&1; then
  echo "==> Installing gh extensions"
  for _ext in{{ range (index $resolved "gh_extensions") }} {{ . | quote }}{{ end }}; do
    if gh extension list 2>/dev/null | grep -q "$_ext"; then
      gh extension upgrade "$_ext" >/dev/null 2>&1 || {
        echo "warning: gh extension upgrade $_ext failed (transient?)" >&2
        _record_install_failure "gh-ext: $_ext (upgrade)"
      }
    else
      gh extension install "$_ext" >/dev/null 2>&1 || {
        echo "warning: gh extension install $_ext failed (rate-limited or unauth)" >&2
        _record_install_failure "gh-ext: $_ext (install)"
      }
    fi
  done
  unset _ext
fi
{{- end }}

# --- install summary ---
# Always print a single-block recap at the end of the script. If anything was
# recorded, it surfaces here as one short list; if not, the user gets one green
# line confirming the run was clean. Either way the script exits 0 so chezmoi
# can proceed to run_onchange_after scripts.
echo
echo "================================================================"
if [ "${#_install_errors[@]}" -eq 0 ]; then
  echo "==> Install summary: all packages installed successfully"
else
  echo "==> Install summary: ${#_install_errors[@]} item(s) reported errors"
  for _err in "${_install_errors[@]}"; do
    echo "    - $_err"
  done
  echo
  echo "    The pipeline continued past these failures. Re-run"
  echo "    \`chezmoi apply --force\` after fixing the underlying issue,"
  echo "    or scroll up for the per-tool error output."
fi
echo "================================================================"
