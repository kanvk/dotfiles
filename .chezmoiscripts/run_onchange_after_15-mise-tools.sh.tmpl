#!/usr/bin/env bash
#
# Provisions mise-managed tools from the tier's `mise` list (.chezmoidata.yaml),
# rendered into ~/.config/mise/config.toml. No-op when the list is empty.
# Two hashes: `include` reads raw template text, so it alone misses data-only edits.
#
# mise-config-hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}
# mise-tools-hash: {{ includeTemplate "resolve-tier" (dict "tier" .tier "tiers" .tiers "acc" dict) | fromJson | dig "mise" (list) | toJson | sha256sum }}
# mise-bin: {{ lookPath "mise" }} (re-fires the skip-recorded run once mise lands on PATH)

set -euo pipefail
{{ template "brew-path-bootstrap" . }}

if ! command -v mise >/dev/null 2>&1; then
  echo "mise not installed yet — skipping mise tool install"
  exit 0
fi

echo "==> Installing mise-managed tools (mise install)"
# Tolerant: a transient download failure (e.g. quarto's GitHub release fetch)
# shouldn't abort the whole apply — warn and let the user re-run by hand.
if ! mise install 2>&1 | tail -20; then
  echo "  (mise install did not complete cleanly — re-run 'mise install'"
  echo "   once your network is in place.)"
fi
