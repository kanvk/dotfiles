{{/*
   chezmoi init-time config.

   This template runs on `chezmoi init` and writes the rendered config to
   ~/.config/chezmoi/chezmoi.toml. Answers are cached via promptStringOnce;
   re-running `chezmoi init` will NOT re-prompt. To re-prompt, edit or
   delete ~/.config/chezmoi/chezmoi.toml then run `chezmoi init` again.
*/}}

{{- $name := promptStringOnce . "name" "Full name (for git config)" -}}
{{- $email := promptStringOnce . "email" "Email (for git config)" -}}
{{- $githubUser := promptStringOnce . "github_user" "GitHub username" -}}
{{- $gpgSigningKey := promptStringOnce . "gpg_signing_key" "GPG signing key fingerprint (leave blank to skip commit signing)" -}}

{{/*
   Optional age encryption using an existing SSH key. age supports SSH keys
   (ed25519/rsa) as identities directly — see https://github.com/FiloSottile/age#ssh-keys.
   Leave both blank to disable encryption. Recommended on machines that hold
   personal SSH keys; skip on disposable / shared boxes.
*/}}
{{- $sshAgeIdentity := promptStringOnce . "ssh_age_identity"  "Path to SSH key for chezmoi-age encryption (blank = disable)" -}}
{{- $sshAgeRecipient := "" -}}
{{- if $sshAgeIdentity -}}
{{- $sshAgeRecipient = promptStringOnce . "ssh_age_recipient" (printf "Public-key string for %s.pub (paste contents)" $sshAgeIdentity) -}}
{{- end -}}

{{/*
   Opt-in to applying the personal-but-not-secret encrypted "locals" tracked
   under encrypted_dot_gitconfig.local etc. (insteadOf rules, GHE alias).
   Disabled by default: someone else cloning this repo can't decrypt these
   anyway, and disposable / test boxes shouldn't pull them in. Enable on
   machines where the matching age identity is available.
*/}}
{{- $encryptLocals := false -}}
{{- if $sshAgeIdentity -}}
{{- $encryptLocals = promptBoolOnce . "encrypt_locals" "Apply encrypted personal locals (~/.gitconfig.local, ~/.ssh/config.local)?" -}}
{{- end -}}

{{/* Derived facts - computed, not prompted */}}
{{- $kernelOsRelease := "" -}}
{{- if hasKey .chezmoi.kernel "osrelease" -}}
  {{- $kernelOsRelease = .chezmoi.kernel.osrelease -}}
{{- end -}}
{{- $isWsl := or (contains "microsoft" (lower $kernelOsRelease)) (ne (env "WSL_DISTRO_NAME") "") -}}

{{- $osId := "" -}}
{{- $osIdLike := "" -}}
{{- if hasKey .chezmoi "osRelease" -}}
  {{- $osId = (.chezmoi.osRelease.id | default "") -}}
  {{- $osIdLike = (.chezmoi.osRelease.idLike | default "") -}}
{{- end -}}
{{- $isDebianLike := or
    (eq $osId "debian")
    (eq $osId "ubuntu")
    (eq $osId "kali")
    (contains "debian" $osIdLike) -}}

{{/*
   Always declare age as the encryption backend so chezmoi can recognize the
   .age suffix on encrypted source files and resolve their destination paths.
   Without this declaration, chezmoi errors with "encryption not configured"
   the moment it scans an encrypted_*.age file — even when .chezmoiignore
   would have filtered the file out anyway. The [age] block (with real
   identity + recipient) is only emitted when the user provided an SSH age
   identity at init time; without it, decryption is never attempted because
   the encrypted-locals files are gated on encrypt_locals=true.
*/}}
encryption = "age"
{{- if and $sshAgeIdentity $sshAgeRecipient }}

[age]
    identity  = {{ $sshAgeIdentity | quote }}
    recipient = {{ $sshAgeRecipient | quote }}
{{- end }}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    github_user = {{ $githubUser | quote }}
    gpg_signing_key = {{ $gpgSigningKey | quote }}
    ssh_age_identity = {{ $sshAgeIdentity | quote }}
    ssh_age_recipient = {{ $sshAgeRecipient | quote }}
    encrypt_locals = {{ $encryptLocals }}
    is_wsl = {{ $isWsl }}
    is_debian_like = {{ $isDebianLike }}
