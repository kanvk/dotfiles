# Test container — Ubuntu latest. The other officially-supported target.
FROM ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive

# Bootstrap prereqs only — the install-packages script handles everything else.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates curl git sudo locales bash zsh && \
    rm -rf /var/lib/apt/lists/* && \
    locale-gen en_US.UTF-8

ENV LANG=en_US.UTF-8 \
    LC_ALL=en_US.UTF-8

RUN useradd -m -s /bin/bash -G sudo testuser && \
    echo 'testuser ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers

USER testuser
WORKDIR /home/testuser
ENV HOME=/home/testuser

CMD ["/bin/bash"]
